import { OneLineInput } from "../components/onelineinput.slint";
import { LoginStyle, OneLineInputStyles } from "../style/defaults.slint";
import { CustomButton } from "../components/button.slint";
import { Icons } from "../style/icons.slint";


export component LoginView inherits Rectangle {

    callback login(string, string, string);  // (server_url, username, password)
    in-out property <string> server-url;
    property <bool> show-password: false;

    background: LoginStyle.background;

    // Responsive input width: at most 300px, but adapt to narrow screens
    property <length> input-width: min(300px, root.width - 180px);
    property <length> label-width: 120px;

    VerticalLayout {
        spacing: 16px;
        alignment: center;

        // Card container
        Rectangle {
            background: #ffffff18;
            border-radius: 16px;
            border-color: #ffffff30;
            border-width: 1px;
            width: min(520px, root.width - 32px);
            x: (root.width - self.width) / 2;

            VerticalLayout {
                spacing: 18px;
                padding: 32px;

                // Title
                Text {
                    text: "Autentificare";
                    font-size: 24px;
                    font-weight: 700;
                    color: #ffffff;
                    horizontal-alignment: center;
                }

                // Server URL field
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Server URL";
                        font-size: LoginStyle.font-size;
                        color: #cbd5e1;
                        font-weight: 500;
                    }
                    server-input := OneLineInput {
                        placeholder-text: "https://example.com";
                        width: parent.width;
                        txt: root.server-url;
                        accepted => {
                            root.login(self.txt, username-input.txt, pw-ti.text);
                        }
                    }
                }

                // Username field
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Username";
                        font-size: LoginStyle.font-size;
                        color: #cbd5e1;
                        font-weight: 500;
                    }
                    username-input := OneLineInput {
                        placeholder-text: "username";
                        width: parent.width;
                        accepted => {
                            root.login(server-input.txt, self.txt, pw-ti.text);
                        }
                    }
                }

                // Password field
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Parola";
                        font-size: LoginStyle.font-size;
                        color: #cbd5e1;
                        font-weight: 500;
                    }
                    password-input := Rectangle {
                        width: parent.width;
                        height: OneLineInputStyles.height;
                        background: OneLineInputStyles.background;
                        border-color: OneLineInputStyles.border-color;
                        border-width: OneLineInputStyles.border-width;
                        border-radius: OneLineInputStyles.border-radius;

                        if pw-ti.text == "": Text {
                            x: 10px;
                            y: (parent.height - self.height) / 2;
                            text: "parola";
                            color: OneLineInputStyles.garied-font-color;
                            font-size: OneLineInputStyles.font-size;
                        }

                        pw-ti := TextInput {
                            x: 10px;
                            width: parent.width - 20px - parent.height;
                            height: parent.height;
                            vertical-alignment: center;
                            font-size: OneLineInputStyles.font-size;
                            color: OneLineInputStyles.font-color;
                            input-type: root.show-password ? InputType.text : InputType.password;
                            accepted => {
                                root.login(server-input.txt, username-input.txt, self.text);
                            }
                        }

                        // Eye toggle — inside the field on the right
                        Rectangle {
                            x: parent.width - self.width - 4px;
                            y: (parent.height - self.height) / 2;
                            width: parent.height - 8px;
                            height: parent.height - 8px;
                            border-radius: 4px;
                            background: eye-touch.has-hover ? #e2e8f0 : transparent;

                            Image {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                width: parent.width - 6px;
                                height: parent.height - 6px;
                                source: root.show-password ? Icons.eye-off : Icons.eye;
                                image-fit: contain;
                                colorize: #94a3b8;
                            }

                            eye-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.show-password = !root.show-password; }
                            }
                        }
                    }
                }

                // Login button
                HorizontalLayout {
                    alignment: center;
                    CustomButton {
                        text: "Log in";
                        width: 180px;
                        height: 44px;
                        clicked => {
                            root.login(server-input.txt, username-input.txt, pw-ti.text);
                        }
                    }
                }
            }
        }
    }
}
