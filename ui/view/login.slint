import { OneLineInput } from "../components/onelineinput.slint";
import { LoginStyle } from "../style/defaults.slint";
import { CustomButton } from "../components/button.slint";


export component LoginView inherits Rectangle {

    callback login(string, string, string);  // (server_url, username, password)
    in-out property <string> server-url;

    background: LoginStyle.background;

    // Responsive input width: at most 300px, but adapt to narrow screens
    property <length> input-width: min(300px, root.width - 180px);
    property <length> label-width: 120px;

    VerticalLayout {
        spacing: 16px;
        alignment: center;

        // Card container
        Rectangle {
            background: #ffffff18;
            border-radius: 16px;
            border-color: #ffffff30;
            border-width: 1px;
            width: min(520px, root.width - 32px);
            x: (root.width - self.width) / 2;

            VerticalLayout {
                spacing: 18px;
                padding: 32px;

                // Title
                Text {
                    text: "Autentificare";
                    font-size: 24px;
                    font-weight: 700;
                    color: #ffffff;
                    horizontal-alignment: center;
                }

                // Server URL field
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Server URL";
                        font-size: LoginStyle.font-size;
                        color: #cbd5e1;
                        font-weight: 500;
                    }
                    server-input := OneLineInput {
                        placeholder-text: "https://example.com";
                        width: parent.width;
                        txt: root.server-url;
                        accepted => {
                            root.login(self.txt, username-input.txt, password-input.txt);
                        }
                    }
                }

                // Username field
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Username";
                        font-size: LoginStyle.font-size;
                        color: #cbd5e1;
                        font-weight: 500;
                    }
                    username-input := OneLineInput {
                        placeholder-text: "username";
                        width: parent.width;
                        accepted => {
                            root.login(server-input.txt, self.txt, password-input.txt);
                        }
                    }
                }

                // Password field
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Parola";
                        font-size: LoginStyle.font-size;
                        color: #cbd5e1;
                        font-weight: 500;
                    }
                    password-input := OneLineInput {
                        placeholder-text: "parola";
                        input-type: password;
                        width: parent.width;
                        accepted => {
                            root.login(server-input.txt, username-input.txt, self.txt);
                        }
                    }
                }

                // Login button
                HorizontalLayout {
                    alignment: center;
                    CustomButton {
                        text: "Log in";
                        width: 180px;
                        height: 44px;
                        clicked => {
                            root.login(server-input.txt, username-input.txt, password-input.txt);
                        }
                    }
                }
            }
        }
    }
}
