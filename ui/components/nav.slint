import { NavbarStyle, ButtonStyles } from "../style/defaults.slint";
import { CustomButton } from "./button.slint";
import { ButtonType } from "../types.slint";
import { OneLineInput } from "./onelineinput.slint";
import { Icons } from "../style/icons.slint";

export component NavBar inherits Rectangle {
    in property <bool> is-admin: false;
    in property <int> cart-count: 0;

    callback go-catalog();
    callback go-cart();
    callback go-create-product();
    callback go-orders();
    callback go-users();
    callback search-changed(string);
    callback download-catalog-pdf();
    callback refresh();

    height: is-admin ? NavbarStyle.admin-height : NavbarStyle.height;
    background: NavbarStyle.background;

    VerticalLayout {
        padding-top: 8px;
        padding-bottom: 8px;
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;

        // Row 1: Always visible — Catalog + Search (stretching) + Cart
        HorizontalLayout {
            spacing: 10px;

            VerticalLayout {
                alignment: center;
                CustomButton {
                    text: "Catalog";
                    clicked => { root.go-catalog(); }
                }
            }

            // Search input — fills remaining space
            // Use Rectangle (not VerticalLayout) to avoid binding loop in HorizontalLayout
            Rectangle {
                horizontal-stretch: 1;
                OneLineInput {
                    x: 0;
                    y: (parent.height - self.height) / 2;
                    width: parent.width;
                    icon: Icons.search;
                    edited(text) => { root.search-changed(text); }
                }
            }

            // Cart icon button
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 46px;
                    height: ButtonStyles.button-height;
                    background: #ffffff20;
                    border-radius: 8px;

                    Image {
                        width: parent.width - 10px;
                        height: parent.height - 10px;
                        x: 5px;
                        y: 5px;
                        source: Icons.cart;
                        image-fit: contain;
                        colorize: #ffffff;
                    }

                    if cart-count > 0: Rectangle {
                        x: 26px;
                        y: -5px;
                        width: 20px;
                        height: 20px;
                        background: #ef4444;
                        border-radius: 10px;
                        Text {
                            width: parent.width;
                            height: parent.height;
                            text: cart-count;
                            color: #ffffff;
                            font-size: 10px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        mouse-cursor: pointer;
                        clicked => { root.go-cart(); }
                    }
                }
            }
        }

        // Row 2: Admin actions (only when is-admin)
        if is-admin: HorizontalLayout {
            spacing: 8px;
            alignment: start;

            CustomButton {
                text: "Creeaza Produs";
                clicked => { root.go-create-product(); }
            }

            CustomButton {
                text: "Comenzi";
                clicked => { root.go-orders(); }
            }

            CustomButton {
                text: "Utilizatori";
                clicked => { root.go-users(); }
            }

            CustomButton {
                text: "Catalog PDF";
                clicked => { root.download-catalog-pdf(); }
            }

            CustomButton {
                text: "Reincarca";
                clicked => { root.refresh(); }
            }
        }
    }
}
