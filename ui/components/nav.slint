import { NavbarStyle, ButtonStyles } from "../style/defaults.slint";
import { CustomButton } from "./button.slint";
import { ButtonType } from "../types.slint";
import { OneLineInput } from "./onelineinput.slint";
import { Icons } from "../style/icons.slint";
import { CheckBox } from "std-widgets.slint";

export component NavBar inherits Rectangle {
    in property <bool> is-admin: false;
    in property <int> cart-count: 0;

    callback go-catalog();
    callback go-cart();
    callback go-create-product();
    callback go-orders();
    callback go-users();
    callback search-changed(string);
    // per-page, order-by, category-break, template
    callback download-catalog-pdf(string, string, bool, string);
    callback refresh();

    property <string> pdf-per-page: "3";
    property <string> pdf-order-by: "price";
    property <bool> pdf-category-break: false;
    property <string> pdf-template: "default";

    height: is-admin ? NavbarStyle.admin-height : NavbarStyle.height;
    background: NavbarStyle.background;

    VerticalLayout {
        padding-top: 8px;
        padding-bottom: 8px;
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;

        // Row 1: Always visible — Logo + Catalog + Search (stretching) + Cart
        HorizontalLayout {
            spacing: 10px;

            // Logo
            VerticalLayout {
                alignment: center;
                Image {
                    width: ButtonStyles.button-height;
                    height: ButtonStyles.button-height;
                    source: @image-url("../../Logo.png");
                    image-fit: contain;
                }
            }

            VerticalLayout {
                alignment: center;
                CustomButton {
                    text: "Catalog";
                    clicked => { root.go-catalog(); }
                }
            }

            // Search input — fills remaining space
            // Use Rectangle (not VerticalLayout) to avoid binding loop in HorizontalLayout
            Rectangle {
                horizontal-stretch: 1;
                OneLineInput {
                    x: 0;
                    y: (parent.height - self.height) / 2;
                    width: parent.width;
                    icon: Icons.search;
                    edited(text) => { root.search-changed(text); }
                }
            }

            // Cart icon button
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 46px;
                    height: ButtonStyles.button-height;
                    background: #ffffff20;
                    border-radius: 8px;

                    Image {
                        width: parent.width - 10px;
                        height: parent.height - 10px;
                        x: 5px;
                        y: 5px;
                        source: Icons.cart;
                        image-fit: contain;
                        colorize: #ffffff;
                    }

                    if cart-count > 0: Rectangle {
                        x: 26px;
                        y: -5px;
                        width: 20px;
                        height: 20px;
                        background: #ef4444;
                        border-radius: 10px;
                        Text {
                            width: parent.width;
                            height: parent.height;
                            text: cart-count;
                            color: #ffffff;
                            font-size: 10px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        mouse-cursor: pointer;
                        clicked => { root.go-cart(); }
                    }
                }
            }
        }

        // Row 2: Admin actions (only when is-admin)
        if is-admin: HorizontalLayout {
            spacing: 8px;
            alignment: start;

            CustomButton {
                text: "Creeaza Produs";
                clicked => { root.go-create-product(); }
            }

            CustomButton {
                text: "Comenzi";
                clicked => { root.go-orders(); }
            }

            CustomButton {
                text: "Utilizatori";
                clicked => { root.go-users(); }
            }

            Rectangle {
                width: 110px;
                height: ButtonStyles.button-height;

                CustomButton {
                    text: "Catalog PDF";
                    width: parent.width;
                    clicked => { pdf-popup.show(); }
                }

                pdf-popup := PopupWindow {
                    x: 0px;
                    y: parent.height + 4px;
                    width: 310px;
                    height: 280px;

                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        background: #ffffff;
                        border-color: #e2e8f0;
                        border-width: 1px;
                        border-radius: 8px;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 10px;

                            Text {
                                text: "Optiuni Catalog PDF";
                                font-size: 14px;
                                font-weight: 700;
                                color: #1e293b;
                            }

                            // Per page
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Text { text: "Per pagina:"; width: 110px; font-size: 13px; color: #475569; vertical-alignment: center; }
                                Rectangle {
                                    width: 60px; height: 30px;
                                    background: #ffffff;
                                    border-color: #94a3b8;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    TextInput {
                                        x: 6px; y: (parent.height - self.height) / 2;
                                        width: parent.width - 12px;
                                        font-size: 13px;
                                        color: #1e293b;
                                        input-type: decimal;
                                        text <=> root.pdf-per-page;
                                    }
                                }
                            }

                            // Sort by
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Text { text: "Sortare:"; width: 110px; font-size: 13px; color: #475569; vertical-alignment: center; }
                                HorizontalLayout {
                                    spacing: 4px;
                                    Rectangle {
                                        property <bool> sel: root.pdf-order-by == "price";
                                        width: 60px; height: 28px;
                                        background: sel ? #3b82f6 : #f1f5f9;
                                        border-radius: 4px;
                                        Text { width: parent.width; height: parent.height; text: "price"; font-size: 12px; color: sel ? #ffffff : #475569; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { clicked => { root.pdf-order-by = "price"; } }
                                    }
                                    Rectangle {
                                        property <bool> sel: root.pdf-order-by == "name";
                                        width: 60px; height: 28px;
                                        background: sel ? #3b82f6 : #f1f5f9;
                                        border-radius: 4px;
                                        Text { width: parent.width; height: parent.height; text: "name"; font-size: 12px; color: sel ? #ffffff : #475569; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { clicked => { root.pdf-order-by = "name"; } }
                                    }
                                    Rectangle {
                                        property <bool> sel: root.pdf-order-by == "dims";
                                        width: 60px; height: 28px;
                                        background: sel ? #3b82f6 : #f1f5f9;
                                        border-radius: 4px;
                                        Text { width: parent.width; height: parent.height; text: "dims"; font-size: 12px; color: sel ? #ffffff : #475569; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { clicked => { root.pdf-order-by = "dims"; } }
                                    }
                                }
                            }

                            // Category break
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Text { text: "Separare categ.:"; width: 110px; font-size: 13px; color: #475569; vertical-alignment: center; }
                                CheckBox {
                                    checked <=> root.pdf-category-break;
                                }
                            }

                            // Template
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Text { text: "Template:"; width: 110px; font-size: 13px; color: #475569; vertical-alignment: center; }
                                Rectangle {
                                    width: 120px; height: 30px;
                                    background: #ffffff;
                                    border-color: #94a3b8;
                                    border-width: 1px;
                                    border-radius: 4px;
                                    TextInput {
                                        x: 6px; y: (parent.height - self.height) / 2;
                                        width: parent.width - 12px;
                                        font-size: 13px;
                                        color: #1e293b;
                                        text <=> root.pdf-template;
                                    }
                                }
                            }

                            CustomButton {
                                text: "Descarca PDF";
                                button-type: ButtonType.Success;
                                clicked => {
                                    root.download-catalog-pdf(
                                        root.pdf-per-page,
                                        root.pdf-order-by,
                                        root.pdf-category-break,
                                        root.pdf-template
                                    );
                                }
                            }
                        }
                    }
                }
            }

            CustomButton {
                text: "Reincarca";
                clicked => { root.refresh(); }
            }
        }
    }
}
