import { ScrollView } from "std-widgets.slint";
import { TableStyle, DetailStyle, ButtonStyles } from "../style/defaults.slint";
import { CustomButton } from "../components/button.slint";
import { SuggestInput } from "../components/suggest-input.slint";
import { ButtonType, ProductFull, VariationDetails } from "../types.slint";
import { Icons } from "../style/icons.slint";

export component ProductDetail inherits Rectangle {
    in property <ProductFull> product;
    in property <bool> is-admin: false;
    in property <[string]> categories: [];

    callback go-back();
    callback add-to-cart(int);
    // variation-id, dims, pack, std, price
    callback update-variation(int, string, string, string, float);
    callback delete-variation(int);
    // dims, pack, std, price
    callback add-variation(string, string, string, float);
    callback delete-product();
    callback change-product-image();
    // name, category
    callback update-product-meta(string, string);

    property <bool> show-add-form: false;
    property <string> new-dims: "";
    property <string> new-pack: "";
    property <string> new-std: "";
    property <string> new-price-str: "";
    property <string> edit-name: product.name;
    property <string> edit-category: product.category;

    // Minimum table width (sum of visible columns + action)
    property <length> table-min-width: 790px;

    VerticalLayout {
        spacing: 0px;

        // Top bar (full-width)
        Rectangle {
            height: 50px;
            background: #ffffff;
            border-color: #e2e8f0;
            border-width: 1px;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                alignment: start;
                spacing: 10px;
                VerticalLayout {
                    alignment: center;
                    CustomButton {
                        text: "< Inapoi";
                        width: 100px;
                        clicked => { root.go-back(); }
                    }
                }
                if root.is-admin: VerticalLayout {
                    alignment: center;
                    CustomButton {
                        text: "Sterge Produs";
                        button-type: ButtonType.Danger;
                        width: 140px;
                        clicked => { root.delete-product(); }
                    }
                }
                if root.is-admin: VerticalLayout {
                    alignment: center;
                    CustomButton {
                        text: "Salveaza Produs";
                        button-type: ButtonType.Success;
                        width: 140px;
                        clicked => {
                            root.update-product-meta(root.edit-name, root.edit-category);
                        }
                    }
                }
            }
        }

        // Product header: image + info (full-width, responsive)
        Rectangle {
            height: DetailStyle.image-height + 50px;
            background: #ffffff;
            border-color: #e2e8f0;
            border-width: 1px;

            HorizontalLayout {
                spacing: 20px;
                padding: 20px;
                alignment: start;

                VerticalLayout {
                    alignment: start;
                    spacing: 6px;
                    Rectangle {
                        width: DetailStyle.image-width;
                        height: DetailStyle.image-height;
                        border-color: #e2e8f0;
                        border-width: 1px;
                        border-radius: 10px;
                        clip: true;
                        Image {
                            width: parent.width;
                            height: parent.height;
                            source: product.image;
                            image-fit: contain;
                        }
                    }
                    if root.is-admin: CustomButton {
                        text: "Schimba imagine";
                        width: DetailStyle.image-width;
                        height: 30px;
                        clicked => { root.change-product-image(); }
                    }
                }

                VerticalLayout {
                    alignment: start;
                    spacing: 8px;
                    horizontal-stretch: 1;

                    // Category: badge (read-only) or text input (admin)
                    if !root.is-admin: Rectangle {
                        width: 140px;
                        height: 26px;
                        background: #3b82f6;
                        border-radius: 5px;
                        Text {
                            width: parent.width;
                            height: parent.height;
                            text: product.category;
                            color: #ffffff;
                            font-size: 12px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    if root.is-admin: HorizontalLayout {
                        spacing: 6px;
                        height: 28px;
                        Text {
                            text: "Categorie:";
                            font-size: 12px;
                            color: #475569;
                            vertical-alignment: center;
                            horizontal-stretch: 0;
                        }
                        SuggestInput {
                            horizontal-stretch: 1;
                            suggestions: root.categories;
                            value <=> root.edit-category;
                            font-size: 12px;
                        }
                    }

                    // Title: static text (read-only) or text input (admin)
                    if !root.is-admin: Text {
                        text: product.name;
                        color: DetailStyle.title-color;
                        font-size: DetailStyle.title-font-size;
                        font-weight: DetailStyle.title-font-weight;
                        wrap: word-wrap;
                    }
                    if root.is-admin: HorizontalLayout {
                        spacing: 6px;
                        height: 32px;
                        Text {
                            text: "Titlu:";
                            font-size: 12px;
                            color: #475569;
                            vertical-alignment: center;
                            horizontal-stretch: 0;
                        }
                        Rectangle {
                            horizontal-stretch: 1;
                            height: 32px;
                            background: #ffffff;
                            border-color: #93c5fd;
                            border-width: 1px;
                            border-radius: 4px;
                            TextInput {
                                x: 6px; y: (parent.height - self.height) / 2;
                                width: parent.width - 12px;
                                vertical-alignment: center;
                                font-size: DetailStyle.title-font-size;
                                font-weight: DetailStyle.title-font-weight;
                                color: DetailStyle.title-color;
                                text <=> root.edit-name;
                            }
                        }
                    }
                }
            }
        }

        // Table section — horizontally scrollable
        ScrollView {
            vertical-stretch: 1;
            viewport-width: max(self.width, root.table-min-width);

            VerticalLayout {

                // Table header
                Rectangle {
                    height: 44px;
                    background: TableStyle.header-background;
                    border-color: TableStyle.border-color;
                    border-width: 1px;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 10px;

                        if product.has-dimensions: Text {
                            width: TableStyle.col-dimensions;
                            text: "Dimensiune";
                            font-size: TableStyle.font-size;
                            font-weight: 600;
                            color: DetailStyle.font-color;
                            vertical-alignment: center;
                        }
                        if product.has-packaging: Text {
                            width: TableStyle.col-packaging;
                            text: "Ambalaj";
                            font-size: TableStyle.font-size;
                            font-weight: 600;
                            color: DetailStyle.font-color;
                            vertical-alignment: center;
                        }
                        if product.has-standard: Text {
                            width: TableStyle.col-standard;
                            text: "Standard";
                            font-size: TableStyle.font-size;
                            font-weight: 600;
                            color: DetailStyle.font-color;
                            vertical-alignment: center;
                        }
                        Text {
                            width: TableStyle.col-price-unit;
                            text: "Pret/unitate";
                            font-size: TableStyle.font-size;
                            font-weight: 600;
                            color: DetailStyle.font-color;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }

                // Variation rows + admin controls
                for variation[i] in product.variations: Rectangle {
                    property <string> edit-dims: variation.dimensions;
                    property <string> edit-pack: variation.packaging;
                    property <string> edit-std: variation.standard;
                    property <string> edit-price: "\{variation.price}";

                    height: root.is-admin ? 110px : TableStyle.row-height;
                    background: Math.mod(i, 2) == 0 ? TableStyle.row-even-background : TableStyle.row-odd-background;
                    border-color: TableStyle.border-color;
                    border-width: 1px;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 10px;

                        if product.has-dimensions && !root.is-admin: Text {
                            width: TableStyle.col-dimensions;
                            text: variation.dimensions;
                            font-size: TableStyle.font-size;
                            color: DetailStyle.font-color;
                            vertical-alignment: center;
                            wrap: word-wrap;
                        }
                        if product.has-dimensions && root.is-admin: VerticalLayout {
                            width: TableStyle.col-dimensions;
                            alignment: center;
                            Rectangle {
                                height: 30px;
                                background: #ffffff;
                                border-color: #cbd5e1;
                                border-width: 1px;
                                border-radius: 4px;
                                TextInput {
                                    x: 6px; y: (parent.height - self.height) / 2;
                                    width: parent.width - 12px;
                                    vertical-alignment: center;
                                    font-size: TableStyle.font-size;
                                    color: DetailStyle.font-color;
                                    text <=> edit-dims;
                                }
                            }
                        }

                        if product.has-packaging && !root.is-admin: Text {
                            width: TableStyle.col-packaging;
                            text: variation.packaging;
                            font-size: TableStyle.font-size;
                            color: DetailStyle.font-color;
                            vertical-alignment: center;
                            wrap: word-wrap;
                        }
                        if product.has-packaging && root.is-admin: VerticalLayout {
                            width: TableStyle.col-packaging;
                            alignment: center;
                            Rectangle {
                                height: 30px;
                                background: #ffffff;
                                border-color: #cbd5e1;
                                border-width: 1px;
                                border-radius: 4px;
                                TextInput {
                                    x: 6px; y: (parent.height - self.height) / 2;
                                    width: parent.width - 12px;
                                    vertical-alignment: center;
                                    font-size: TableStyle.font-size;
                                    color: DetailStyle.font-color;
                                    text <=> edit-pack;
                                }
                            }
                        }

                        if product.has-standard && !root.is-admin: Text {
                            width: TableStyle.col-standard;
                            text: variation.standard;
                            font-size: TableStyle.font-size;
                            color: DetailStyle.font-color;
                            vertical-alignment: center;
                            wrap: word-wrap;
                        }
                        if product.has-standard && root.is-admin: VerticalLayout {
                            width: TableStyle.col-standard;
                            alignment: center;
                            Rectangle {
                                height: 30px;
                                background: #ffffff;
                                border-color: #cbd5e1;
                                border-width: 1px;
                                border-radius: 4px;
                                TextInput {
                                    x: 6px; y: (parent.height - self.height) / 2;
                                    width: parent.width - 12px;
                                    vertical-alignment: center;
                                    font-size: TableStyle.font-size;
                                    color: DetailStyle.font-color;
                                    text <=> edit-std;
                                }
                            }
                        }

                        if !root.is-admin: Text {
                            width: TableStyle.col-price-unit;
                            text: variation.price-per-unit;
                            font-size: TableStyle.font-size;
                            color: DetailStyle.font-color;
                            vertical-alignment: center;
                        }
                        if root.is-admin: VerticalLayout {
                            width: TableStyle.col-price-unit;
                            alignment: center;
                            Rectangle {
                                height: 30px;
                                background: #ffffff;
                                border-color: #cbd5e1;
                                border-width: 1px;
                                border-radius: 4px;
                                TextInput {
                                    x: 6px; y: (parent.height - self.height) / 2;
                                    width: parent.width - 12px;
                                    vertical-alignment: center;
                                    font-size: TableStyle.font-size;
                                    color: DetailStyle.font-color;
                                    text <=> edit-price;
                                }
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 4px;
                            horizontal-stretch: 1;

                            CustomButton {
                                text: "Adauga in cos";
                                button-type: ButtonType.Success;
                                width: TableStyle.col-action;
                                height: 30px;
                                clicked => { root.add-to-cart(variation.id); }
                            }

                            if root.is-admin: CustomButton {
                                text: "Actualizeaza";
                                width: TableStyle.col-action;
                                height: 26px;
                                clicked => {
                                    root.update-variation(
                                        variation.id,
                                        edit-dims, edit-pack, edit-std,
                                        edit-price.to-float()
                                    );
                                }
                            }

                            if root.is-admin: CustomButton {
                                text: "Sterge varianta";
                                button-type: ButtonType.Danger;
                                width: TableStyle.col-action;
                                height: 26px;
                                clicked => { root.delete-variation(variation.id); }
                            }
                        }
                    }
                }

                // Admin: Add variation bar
                if root.is-admin: Rectangle {
                    height: 50px;
                    background: #f8fafc;
                    border-color: #e2e8f0;
                    border-width: 1px;

                    HorizontalLayout {
                        padding-left: 10px;
                        alignment: start;
                        VerticalLayout {
                            alignment: center;
                            CustomButton {
                                text: "+ Adauga varianta";
                                width: 160px;
                                clicked => { root.show-add-form = !root.show-add-form; }
                            }
                        }
                    }
                }

                // Admin: Inline add form
                if root.is-admin && root.show-add-form: Rectangle {
                    height: 90px;
                    background: #eff6ff;
                    border-color: #93c5fd;
                    border-width: 1px;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 10px;
                        alignment: start;

                        VerticalLayout {
                            spacing: 4px;
                            alignment: center;
                            Text { text: "Dimensiune:"; font-size: 12px; color: #475569; }
                            Rectangle {
                                width: TableStyle.col-dimensions;
                                height: 32px;
                                background: #ffffff;
                                border-color: #93c5fd;
                                border-width: 1px;
                                border-radius: 4px;
                                TextInput {
                                    x: 6px; y: (parent.height - self.height) / 2;
                                    width: parent.width - 12px;
                                    vertical-alignment: center;
                                    font-size: TableStyle.font-size;
                                    color: #1e293b;
                                    text <=> root.new-dims;
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            alignment: center;
                            Text { text: "Ambalaj:"; font-size: 12px; color: #475569; }
                            Rectangle {
                                width: TableStyle.col-packaging;
                                height: 32px;
                                background: #ffffff;
                                border-color: #93c5fd;
                                border-width: 1px;
                                border-radius: 4px;
                                TextInput {
                                    x: 6px; y: (parent.height - self.height) / 2;
                                    width: parent.width - 12px;
                                    vertical-alignment: center;
                                    font-size: TableStyle.font-size;
                                    color: #1e293b;
                                    text <=> root.new-pack;
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            alignment: center;
                            Text { text: "Standard:"; font-size: 12px; color: #475569; }
                            Rectangle {
                                width: TableStyle.col-standard;
                                height: 32px;
                                background: #ffffff;
                                border-color: #93c5fd;
                                border-width: 1px;
                                border-radius: 4px;
                                TextInput {
                                    x: 6px; y: (parent.height - self.height) / 2;
                                    width: parent.width - 12px;
                                    vertical-alignment: center;
                                    font-size: TableStyle.font-size;
                                    color: #1e293b;
                                    text <=> root.new-std;
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            alignment: center;
                            Text { text: "Pret:"; font-size: 12px; color: #475569; }
                            Rectangle {
                                width: 90px;
                                height: 32px;
                                background: #ffffff;
                                border-color: #93c5fd;
                                border-width: 1px;
                                border-radius: 4px;
                                TextInput {
                                    x: 6px; y: (parent.height - self.height) / 2;
                                    width: parent.width - 12px;
                                    vertical-alignment: center;
                                    font-size: TableStyle.font-size;
                                    color: #1e293b;
                                    input-type: decimal;
                                    text <=> root.new-price-str;
                                }
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 4px;
                            CustomButton {
                                text: "Salveaza";
                                button-type: ButtonType.Success;
                                width: 100px;
                                height: 30px;
                                clicked => {
                                    root.add-variation(
                                        root.new-dims, root.new-pack,
                                        root.new-std,
                                        root.new-price-str.to-float()
                                    );
                                    root.show-add-form = false;
                                    root.new-dims = "";
                                    root.new-pack = "";
                                    root.new-std = "";
                                    root.new-price-str = "";
                                }
                            }
                            CustomButton {
                                text: "Anuleaza";
                                button-type: ButtonType.Danger;
                                width: 100px;
                                height: 30px;
                                clicked => { root.show-add-form = false; }
                            }
                        }
                    }
                }
            }
        }
    }
}
