import { ScrollView } from "std-widgets.slint";
import { MainWindowStyle } from "style/defaults.slint";
import { NavBar } from "components/nav.slint";
import { Filter } from "components/filter.slint";
import { Catalog } from "view/catalog.slint";
import { LoginView } from "view/login.slint";
import { ProductDetail } from "view/product-detail.slint";
import { CartView } from "view/cart.slint";
import { OrdersView } from "view/orders.slint";
import { UsersView } from "view/users.slint";
import { CreateProductView } from "view/create.slint";
import { ProductDetails, ProductFull, CartItem, OrderData, UserData, VariationInput, TemplateItem } from "types.slint";

export component Main inherits Window {
    in-out property <bool> logged: false;
    in-out property <bool> is-admin: false;
    in-out property <int> current-view: 0;  // 0=catalog 1=detail 2=cart 3=orders 4=users 5=create-product

    in-out property <[ProductDetails]> products;
    in-out property <[string]> categories: ["Tot"];
    in-out property <string> search-query: "";
    in-out property <string> filter-category: "Tot";
    in-out property <string> sort-by: "Pret ↑";
    in-out property <ProductFull> selected-product;
    in-out property <[CartItem]> cart-items;
    in-out property <int> cart-count: 0;
    in-out property <string> cart-total: "0.00 RON";
    in-out property <[OrderData]> orders;
    in-out property <[UserData]> users;
    in-out property <string> create-image-path: "";
    in-out property <[VariationInput]> create-variations;
    in-out property <string> create-name: "";
    in-out property <string> create-category: "";
    in-out property <string> create-desc: "";
    in-out property <bool> create-include-in-catalog: true;

    in-out property <[TemplateItem]> templates;
    in-out property <string> server-url;
    in-out property <string> toast-message: "";
    in-out property <bool> toast-visible: false;
    callback load-templates();
    callback login(string, string, string);  // (server_url, username, password)
    callback open-product(int);
    callback search(string);
    callback filter-changed(string);
    callback add-to-cart(int);
    callback remove-from-cart(int);
    callback update-quantity(int, int);
    callback send-order(string, string, string, float);
    callback clear-cart();
    // Product admin
    // name, category, description, image-path, include-in-catalog
    callback create-product(string, string, string, string, bool);
    callback select-image-create();
    callback add-variation-row();
    callback remove-variation-row(int);
    // index, dims, pack, std, price
    callback variation-field-changed(int, string, string, string, string);
    callback clear-create-variations();
    callback delete-product(int);
    // product-id, variation-id, dims, pack, std, price
    callback update-variation(int, int, string, string, string, float);
    callback delete-variation(int, int);
    // product-id, dims, pack, std, price
    callback add-variation(int, string, string, string, float);
    callback change-product-image(int);
    // product-id, name, category
    callback update-product-meta(int, string, string);
    // product-id, include
    callback toggle-include-in-catalog(int, bool);
    callback duplicate-product(int);
    // Orders
    callback load-orders();
    // per-page, order-by, category-break, template-id
    callback download-catalog-pdf(string, string, bool, int);
    callback download-export-xlsx();
    callback refresh();
    callback logout();
    // Users
    callback load-users();
    callback create-user(string, string, string, bool, bool);
    callback update-user(int, string, string, bool, bool);
    callback delete-user(int);

    title: "Vadini";
    min-width: 320px;
    background: MainWindowStyle.background;
    icon: @image-url("../Logo.png");

    if !logged: LoginView {
        width: root.width;
        height: root.height;
        server-url: root.server-url;
        login(url, user, pass) => { root.login(url, user, pass); }
    }

    if logged: VerticalLayout {
        spacing: 0px;

        NavBar {
            is-admin: root.is-admin;
            cart-count: root.cart-count;
            templates: root.templates;
            go-catalog => { root.current-view = 0; }
            go-cart => { root.current-view = 2; }
            go-create-product => {
                root.create-name = "";
                root.create-category = "";
                root.create-desc = "";
                root.create-include-in-catalog = true;
                root.create-image-path = "";
                root.clear-create-variations();
                root.current-view = 5;
            }
            go-orders => {
                root.current-view = 3;
                root.load-orders();
            }
            go-users => {
                root.current-view = 4;
                root.load-users();
            }
            search-changed(q) => { root.search(q); }
            download-catalog-pdf(pp, ob, cb, tmpl) => { root.download-catalog-pdf(pp, ob, cb, tmpl); }
            download-export-xlsx => { root.download-export-xlsx(); }
            refresh => { root.refresh(); }
            logout => { root.logout(); }
        }

        if current-view == 0: VerticalLayout {
            spacing: 5px;

            Filter {
                categories: root.categories;
                category-selected(cat) => { root.filter-changed(cat); }
                sort-changed(val) => {
                    root.sort-by = val;
                    root.filter-changed(root.filter-category);
                }
            }

            ScrollView {
                catalog-view := Catalog {
                    width: parent.width;
                    products: root.products;
                    open-product(id) => { root.open-product(id); }
                }
                viewport-height: catalog-view.height;
            }
        }

        if current-view == 1: ProductDetail {
            product: root.selected-product;
            is-admin: root.is-admin;
            categories: root.categories;
            go-back => { root.current-view = 0; }
            add-to-cart(vid) => { root.add-to-cart(vid); }
            update-variation(vid, d, pk, st, pr) => {
                root.update-variation(root.selected-product.id, vid, d, pk, st, pr);
            }
            delete-variation(vid) => {
                root.delete-variation(root.selected-product.id, vid);
            }
            add-variation(d, pk, st, pr) => {
                root.add-variation(root.selected-product.id, d, pk, st, pr);
            }
            delete-product => {
                root.delete-product(root.selected-product.id);
            }
            change-product-image => {
                root.change-product-image(root.selected-product.id);
            }
            update-product-meta(name, cat) => {
                root.update-product-meta(root.selected-product.id, name, cat);
            }
            toggle-include-in-catalog(include) => {
                root.toggle-include-in-catalog(root.selected-product.id, include);
            }
            duplicate-product => {
                root.duplicate-product(root.selected-product.id);
            }
        }

        if current-view == 2: CartView {
            cart-items: root.cart-items;
            cart-total: root.cart-total;
            go-back => { root.current-view = 0; }
            remove-from-cart(vid) => { root.remove-from-cart(vid); }
            update-quantity(vid, qty) => { root.update-quantity(vid, qty); }
            send-order(cn, ai, ad, disc) => { root.send-order(cn, ai, ad, disc); }
            clear-cart => { root.clear-cart(); }
        }

        if current-view == 3: OrdersView {
            orders: root.orders;
            go-back => { root.current-view = 0; }
            refresh-orders => { root.load-orders(); }
        }

        if current-view == 4: UsersView {
            users: root.users;
            go-back => { root.current-view = 0; }
            refresh-users => { root.load-users(); }
            create-user(u, e, p, a, s) => { root.create-user(u, e, p, a, s); }
            update-user(id, u, e, a, s) => { root.update-user(id, u, e, a, s); }
            delete-user(id) => { root.delete-user(id); }
        }

        if current-view == 5: CreateProductView {
            categories: root.categories;
            image-path <=> root.create-image-path;
            variation-list <=> root.create-variations;
            name-val <=> root.create-name;
            category-val <=> root.create-category;
            desc-val <=> root.create-desc;
            include-in-catalog-val <=> root.create-include-in-catalog;
            go-back => { root.current-view = 0; }
            select-image => { root.select-image-create(); }
            add-variation-row => { root.add-variation-row(); }
            remove-variation-row(i) => { root.remove-variation-row(i); }
            variation-field-changed(i, d, pk, st, pr) => {
                root.variation-field-changed(i, d, pk, st, pr);
            }
            create-product(n, c, desc, img, inc) => {
                root.create-product(n, c, desc, img, inc);
            }
        }
    }

    // Auto-dismiss toast timer
    toast-timer := Timer {
        interval: 3s;
        running: root.toast-visible;
        triggered => { root.toast-visible = false; }
    }

    // Toast notification overlay
    if toast-visible: Rectangle {
        z: 100;
        width: min(380px, root.width - 32px);
        height: toast-text.preferred-height + 24px;
        x: (root.width - self.width) / 2;
        y: root.height - self.height - 24px;
        background: #1e293b;
        border-radius: 8px;
        drop-shadow-blur: 16px;
        drop-shadow-color: #00000050;
        drop-shadow-offset-y: 4px;

        toast-text := Text {
            x: 16px;
            y: 12px;
            width: parent.width - 32px;
            text: root.toast-message;
            color: #ffffff;
            font-size: 13px;
            wrap: word-wrap;
        }
    }
}
