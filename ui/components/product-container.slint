import { ProductContainerStyles } from "../style/defaults.slint";

export component ProductContainer inherits Rectangle {
    in property <string> title;
    in property <image> image;
    in property <string> description;
    in property <string> category: "Uncategorized";
    in property <string> price: "Pret: N/A";

    callback clicked();

    background: touch.has-hover ? #f0f7ff : ProductContainerStyles.background;
    border-color: touch.has-hover ? #93c5fd : ProductContainerStyles.border-color;
    border-width: 1px;
    border-radius: 12px;
    width: ProductContainerStyles.width;
    height: ProductContainerStyles.height;

    animate background { duration: 150ms; }
    animate border-color { duration: 150ms; }

    VerticalLayout {
        alignment: start;
        spacing: 4px;
        padding: 10px;

        // Category badge
        Rectangle {
            width: parent.width - 20px;
            height: ProductContainerStyles.category-height;
            background: ProductContainerStyles.category-background;
            border-radius: ProductContainerStyles.category-border-radius;
            Text {
                width: parent.width;
                height: parent.height;
                text: category;
                font-size: ProductContainerStyles.category-font-size;
                font-weight: ProductContainerStyles.category-font-weight;
                color: ProductContainerStyles.category-font-color;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        // Product image
        HorizontalLayout {
            alignment: center;
            padding-top: 4px;
            Image {
                width: ProductContainerStyles.image-width;
                height: ProductContainerStyles.image-height;
                source: image;
                image-fit: contain;
            }
        }

        // Title
        Text {
            text: title;
            font-size: ProductContainerStyles.title-font-size;
            font-weight: ProductContainerStyles.title-font-weight;
            color: ProductContainerStyles.title-color;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        // Description
        Text {
            text: description;
            vertical-alignment: top;
            horizontal-alignment: center;
            wrap: word-wrap;
            font-size: ProductContainerStyles.font-size;
            font-weight: ProductContainerStyles.font-weight;
            color: ProductContainerStyles.font-color;
            overflow: elide;
        }

        // Price
        Text {
            text: price;
            font-size: ProductContainerStyles.title-font-size;
            font-weight: ProductContainerStyles.title-font-weight;
            color: #3b82f6;
            horizontal-alignment: center;
        }
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}
