import { Button, VerticalBox, ScrollView } from "std-widgets.slint";
import { MainWindowStyle } from "style/defaults.slint";
import { NavBar } from "components/nav.slint";
import { Filter } from "components/filter.slint";
import { Catalog } from "view/catalog.slint";


export component Main inherits Window {
    width: MainWindowStyle.width;
    height: MainWindowStyle.height;
    background: MainWindowStyle.background;

    VerticalLayout {
        spacing: 5px;
        NavBar { }
        Filter {
            x: 10px;
        }
        ScrollView {
            catalog-view := Catalog {
                width: parent.width;
                products: [];
            }
            viewport-height: catalog-view.height;
        }
    }
}
