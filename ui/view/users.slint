import { ScrollView } from "std-widgets.slint";
import { TableStyle, ButtonStyles } from "../style/defaults.slint";
import { CustomButton } from "../components/button.slint";
import { OneLineInput } from "../components/onelineinput.slint";
import { ButtonType, UserData } from "../types.slint";

export component UsersView inherits Rectangle {
    in property <[UserData]> users;
    callback go-back();
    callback refresh-users();
    callback create-user(string, string, string, bool, bool);
    callback update-user(int, string, string, bool, bool);
    callback delete-user(int);

    property <bool> show-create-form: false;
    property <string> new-username: "";
    property <string> new-email: "";
    property <string> new-password: "";
    property <bool> new-is-superuser: false;

    property <length> table-min-width: 780px;

    VerticalLayout {
        spacing: 0px;

        // Top bar (full-width)
        Rectangle {
            height: 50px;
            background: #ffffff;
            border-color: #e2e8f0;
            border-width: 1px;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                alignment: start;
                spacing: 10px;
                VerticalLayout {
                    alignment: center;
                    CustomButton {
                        text: "< Inapoi";
                        width: 100px;
                        clicked => { root.go-back(); }
                    }
                }
                VerticalLayout {
                    alignment: center;
                    CustomButton {
                        text: "+ Utilizator";
                        button-type: ButtonType.Success;
                        width: 120px;
                        clicked => { root.show-create-form = !root.show-create-form; }
                    }
                }
                VerticalLayout {
                    alignment: center;
                    CustomButton {
                        text: "Reincarca";
                        width: 100px;
                        clicked => { root.refresh-users(); }
                    }
                }
            }
        }

        // Create form (full-width, collapsible)
        if root.show-create-form: Rectangle {
            background: #eff6ff;
            border-color: #bfdbfe;
            border-width: 1px;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: "Utilizator Nou";
                    font-size: 15px;
                    font-weight: 700;
                    color: #1e293b;
                }

                HorizontalLayout {
                    spacing: 16px;
                    alignment: start;

                    VerticalLayout {
                        spacing: 4px;
                        alignment: start;
                        Text { text: "Username"; font-size: 12px; color: #475569; font-weight: 500; }
                        OneLineInput {
                            width: 180px;
                            placeholder-text: "username";
                            edited(t) => { root.new-username = t; }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        alignment: start;
                        Text { text: "Email"; font-size: 12px; color: #475569; font-weight: 500; }
                        OneLineInput {
                            width: 220px;
                            placeholder-text: "email@example.com";
                            edited(t) => { root.new-email = t; }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        alignment: start;
                        Text { text: "Parola"; font-size: 12px; color: #475569; font-weight: 500; }
                        OneLineInput {
                            width: 160px;
                            placeholder-text: "••••••••";
                            input-type: password;
                            edited(t) => { root.new-password = t; }
                        }
                    }

                    // Admin toggle
                    VerticalLayout {
                        spacing: 4px;
                        alignment: start;
                        Text { text: "Admin"; font-size: 12px; color: #475569; font-weight: 500; }
                        Rectangle {
                            width: 52px;
                            height: ButtonStyles.button-height;
                            background: root.new-is-superuser ? #3b82f6 : #cbd5e1;
                            border-radius: ButtonStyles.button-height / 2;
                            animate background { duration: 150ms; }

                            Rectangle {
                                x: root.new-is-superuser ? parent.width - self.width - 4px : 4px;
                                y: (parent.height - self.height) / 2;
                                width: parent.height - 8px;
                                height: parent.height - 8px;
                                background: #ffffff;
                                border-radius: self.height / 2;
                                animate x { duration: 150ms; }
                            }

                            TouchArea {
                                clicked => { root.new-is-superuser = !root.new-is-superuser; }
                            }
                        }
                    }

                    // Spacer + buttons aligned right
                    Rectangle { horizontal-stretch: 1; }

                    VerticalLayout {
                        alignment: center;
                        spacing: 6px;
                        CustomButton {
                            text: "Salveaza";
                            button-type: ButtonType.Success;
                            width: 110px;
                            height: 34px;
                            clicked => {
                                root.create-user(
                                    root.new-username, root.new-email,
                                    root.new-password, true, root.new-is-superuser
                                );
                                root.show-create-form = false;
                                root.new-username = "";
                                root.new-email = "";
                                root.new-password = "";
                                root.new-is-superuser = false;
                            }
                        }
                        CustomButton {
                            text: "Anuleaza";
                            button-type: ButtonType.Danger;
                            width: 110px;
                            height: 34px;
                            clicked => { root.show-create-form = false; }
                        }
                    }
                }
            }
        }

        // Table — horizontally + vertically scrollable
        ScrollView {
            vertical-stretch: 1;
            viewport-width: max(self.width, root.table-min-width);

            VerticalLayout {

                // Table header
                Rectangle {
                    height: 44px;
                    background: TableStyle.header-background;
                    border-color: TableStyle.border-color;
                    border-width: 1px;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 0px;
                        Text { width: 50px;  text: "ID";       font-size: TableStyle.font-size; font-weight: 600; color: TableStyle.font-color; vertical-alignment: center; }
                        Text { width: 200px; text: "Username"; font-size: TableStyle.font-size; font-weight: 600; color: TableStyle.font-color; vertical-alignment: center; }
                        Text { width: 250px; text: "Email";    font-size: TableStyle.font-size; font-weight: 600; color: TableStyle.font-color; vertical-alignment: center; }
                        Text { width: 80px;  text: "Activ";   font-size: TableStyle.font-size; font-weight: 600; color: TableStyle.font-color; vertical-alignment: center; }
                        Text { width: 80px;  text: "Admin";   font-size: TableStyle.font-size; font-weight: 600; color: TableStyle.font-color; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }

                // User rows
                for user[i] in users: Rectangle {
                    property <string> edit-name: user.name;
                    property <string> edit-email: user.email;
                    property <bool> edit-active: user.is-active;
                    property <bool> edit-super: user.is-superuser;

                    height: 80px;
                    background: Math.mod(i, 2) == 0 ? TableStyle.row-even-background : TableStyle.row-odd-background;
                    border-color: TableStyle.border-color;
                    border-width: 1px;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 0px;

                        VerticalLayout {
                            width: 50px;
                            alignment: center;
                            Text { text: "\{user.id}"; font-size: TableStyle.font-size; color: TableStyle.font-color; font-weight: 600; }
                        }

                        VerticalLayout {
                            width: 200px;
                            alignment: center;
                            Rectangle {
                                height: 32px;
                                background: #ffffff;
                                border-color: #cbd5e1;
                                border-width: 1px;
                                border-radius: 4px;
                                TextInput {
                                    x: 6px; y: (parent.height - self.height) / 2;
                                    width: parent.width - 12px;
                                    vertical-alignment: center;
                                    font-size: TableStyle.font-size;
                                    color: TableStyle.font-color;
                                    text <=> edit-name;
                                }
                            }
                        }

                        VerticalLayout {
                            width: 250px;
                            alignment: center;
                            Rectangle {
                                height: 32px;
                                background: #ffffff;
                                border-color: #cbd5e1;
                                border-width: 1px;
                                border-radius: 4px;
                                TextInput {
                                    x: 6px; y: (parent.height - self.height) / 2;
                                    width: parent.width - 12px;
                                    vertical-alignment: center;
                                    font-size: TableStyle.font-size;
                                    color: TableStyle.font-color;
                                    text <=> edit-email;
                                }
                            }
                        }

                        VerticalLayout {
                            width: 80px;
                            alignment: center;
                            Text {
                                text: user.is-active ? "Da" : "Nu";
                                font-size: TableStyle.font-size;
                                color: user.is-active ? #15803d : #dc2626;
                                font-weight: 600;
                            }
                        }
                        VerticalLayout {
                            width: 80px;
                            alignment: center;
                            Text {
                                text: user.is-superuser ? "Da" : "Nu";
                                font-size: TableStyle.font-size;
                                color: user.is-superuser ? #1d4ed8 : #64748b;
                                font-weight: 600;
                            }
                        }

                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 4px;
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                CustomButton {
                                    text: "Actualizeaza";
                                    width: 120px;
                                    height: 30px;
                                    clicked => {
                                        root.update-user(
                                            user.id,
                                            edit-name, edit-email,
                                            edit-active, edit-super
                                        );
                                    }
                                }
                                CustomButton {
                                    text: "Sterge";
                                    button-type: ButtonType.Danger;
                                    width: 80px;
                                    height: 30px;
                                    clicked => { root.delete-user(user.id); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
