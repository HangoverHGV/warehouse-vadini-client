import { OneLineInput } from "../components/onelineinput.slint";
import { LoginStyle, OneLineInputStyles } from "../style/defaults.slint";
import { CustomButton } from "../components/button.slint";
import { Icons } from "../style/icons.slint";


export component LoginView inherits Rectangle {

    callback login(string, string, string);  // (server_url, username, password)
    in-out property <string> server-url;
    property <bool> show-password: false;

    background: LoginStyle.background;

    // Responsive input width: at most 300px, but adapt to narrow screens
    property <length> input-width: min(300px, root.width - 180px);
    property <length> label-width: 120px;

    VerticalLayout {
        spacing: 16px;
        alignment: center;

        // Card container
        Rectangle {
            background: #ffffff18;
            border-radius: 16px;
            border-color: #ffffff30;
            border-width: 1px;
            width: min(520px, root.width - 32px);
            x: (root.width - self.width) / 2;

            VerticalLayout {
                spacing: 18px;
                padding: 32px;

                // Title
                Text {
                    text: "Autentificare";
                    font-size: 24px;
                    font-weight: 700;
                    color: #ffffff;
                    horizontal-alignment: center;
                }

                // Server URL field
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Server URL";
                        font-size: LoginStyle.font-size;
                        color: #cbd5e1;
                        font-weight: 500;
                    }
                    server-input := OneLineInput {
                        placeholder-text: "https://example.com";
                        width: parent.width;
                        txt: root.server-url;
                        accepted => {
                            root.login(self.txt, username-input.txt, password-input.txt);
                        }
                    }
                }

                // Username field
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Username";
                        font-size: LoginStyle.font-size;
                        color: #cbd5e1;
                        font-weight: 500;
                    }
                    username-input := OneLineInput {
                        placeholder-text: "username";
                        width: parent.width;
                        accepted => {
                            root.login(server-input.txt, self.txt, password-input.txt);
                        }
                    }
                }

                // Password field
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Parola";
                        font-size: LoginStyle.font-size;
                        color: #cbd5e1;
                        font-weight: 500;
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        password-input := OneLineInput {
                            placeholder-text: "parola";
                            input-type: root.show-password ? InputType.text : InputType.password;
                            horizontal-stretch: 1;
                            accepted => {
                                root.login(server-input.txt, username-input.txt, self.txt);
                            }
                        }
                        // Eye toggle button
                        Rectangle {
                            width: 38px;
                            height: password-input.height;
                            background: #ffffff18;
                            border-color: #ffffff30;
                            border-width: 1px;
                            border-radius: 8px;

                            Image {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                width: parent.width - 12px;
                                height: parent.height - 12px;
                                source: root.show-password ? Icons.eye-off : Icons.eye;
                                image-fit: contain;
                                colorize: #cbd5e1;
                            }

                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.show-password = !root.show-password; }
                            }
                        }
                    }
                }

                // Login button
                HorizontalLayout {
                    alignment: center;
                    CustomButton {
                        text: "Log in";
                        width: 180px;
                        height: 44px;
                        clicked => {
                            root.login(server-input.txt, username-input.txt, password-input.txt);
                        }
                    }
                }
            }
        }
    }
}
