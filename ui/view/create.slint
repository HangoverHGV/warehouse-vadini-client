import { ScrollView } from "std-widgets.slint";
import { TableStyle, ButtonStyles } from "../style/defaults.slint";
import { CustomButton } from "../components/button.slint";
import { OneLineInput } from "../components/onelineinput.slint";
import { ButtonType, VariationInput } from "../types.slint";

export component CreateProductView inherits Rectangle {
    callback go-back();
    // name, category, description, image-path
    callback create-product(string, string, string, string);
    callback select-image();
    callback add-variation-row();
    callback remove-variation-row(int);
    // index, dims, pack, std, price
    callback variation-field-changed(int, string, string, string, string);

    in-out property <string> image-path: "";
    in-out property <[VariationInput]> variation-list;

    property <string> name-val: "";
    property <string> category-val: "";
    property <string> desc-val: "";

    // Minimum width for the variations table
    property <length> variations-min-width: 600px;

    VerticalLayout {
        spacing: 0px;

        // Top bar (full-width)
        Rectangle {
            height: 50px;
            background: #ffffff;
            border-color: #e2e8f0;
            border-width: 1px;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                alignment: start;
                spacing: 10px;
                VerticalLayout {
                    alignment: center;
                    CustomButton {
                        text: "< Inapoi";
                        width: 100px;
                        clicked => { root.go-back(); }
                    }
                }
                VerticalLayout {
                    alignment: center;
                    CustomButton {
                        text: "Creeaza Produs";
                        button-type: ButtonType.Success;
                        width: 160px;
                        clicked => {
                            root.create-product(
                                root.name-val,
                                root.category-val,
                                root.desc-val,
                                root.image-path
                            );
                        }
                    }
                }
            }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 0px;

                // Product info section (responsive, no horizontal scroll needed)
                Rectangle {
                    background: #ffffff;
                    border-color: #e2e8f0;
                    border-width: 1px;

                    VerticalLayout {
                        spacing: 16px;
                        padding: 24px;

                        Text {
                            text: "Creeaza Produs Nou";
                            font-size: 20px;
                            font-weight: 700;
                            color: #1e293b;
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: start;
                            Text { text: "Nume produs:"; width: 140px; font-size: 14px; vertical-alignment: center; color: #475569; }
                            OneLineInput {
                                width: min(320px, root.width - 200px);
                                placeholder-text: "Nume produs";
                                edited(t) => { root.name-val = t; }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: start;
                            Text { text: "Categorie:"; width: 140px; font-size: 14px; vertical-alignment: center; color: #475569; }
                            OneLineInput {
                                width: min(320px, root.width - 200px);
                                placeholder-text: "Categorie";
                                edited(t) => { root.category-val = t; }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: start;
                            Text { text: "Descriere:"; width: 140px; font-size: 14px; vertical-alignment: center; color: #475569; }
                            Rectangle {
                                width: min(320px, root.width - 200px);
                                height: 80px;
                                background: #ffffff;
                                border-color: #94a3b8;
                                border-width: 1.5px;
                                border-radius: 8px;

                                if root.desc-val == "": Text {
                                    x: 10px;
                                    y: 8px;
                                    text: "Descriere produs";
                                    color: #94a3b8;
                                    font-size: 14px;
                                }

                                TextInput {
                                    x: 10px; y: 8px;
                                    width: parent.width - 20px;
                                    height: parent.height - 16px;
                                    font-size: 14px;
                                    color: #1e293b;
                                    wrap: word-wrap;
                                    text <=> root.desc-val;
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: start;
                            Text { text: "Imagine:"; width: 140px; font-size: 14px; vertical-alignment: center; color: #475569; }
                            VerticalLayout {
                                alignment: center;
                                spacing: 4px;
                                CustomButton {
                                    text: "Alege imagine";
                                    width: 140px;
                                    clicked => { root.select-image(); }
                                }
                                Text {
                                    text: root.image-path == "" ? "Nicio imagine selectata" : root.image-path;
                                    font-size: 12px;
                                    color: root.image-path == "" ? #94a3b8 : #475569;
                                    wrap: word-wrap;
                                    width: min(320px, root.width - 200px);
                                }
                            }
                        }
                    }
                }

                // Variations section — horizontally scrollable for small screens
                Rectangle {
                    background: #f8fafc;
                    border-color: #e2e8f0;
                    border-width: 1px;

                    VerticalLayout {
                        spacing: 0px;
                        padding: 16px;

                        // Section header (full-width)
                        HorizontalLayout {
                            alignment: space-between;
                            spacing: 10px;
                            Text {
                                text: "Variante";
                                font-size: 16px;
                                font-weight: 700;
                                color: #1e293b;
                                vertical-alignment: center;
                            }
                            CustomButton {
                                text: "+ Adauga varianta";
                                button-type: ButtonType.Success;
                                width: 160px;
                                height: 34px;
                                clicked => { root.add-variation-row(); }
                            }
                        }

                        // Scrollable table area
                        ScrollView {
                            viewport-width: max(self.width, root.variations-min-width);

                            VerticalLayout {
                                // Column header
                                Rectangle {
                                    height: 36px;
                                    background: #e2e8f0;
                                    border-radius: 4px;

                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 8px;
                                        Text { width: 140px; text: "Dimensiune"; font-size: 13px; font-weight: 600; color: #475569; vertical-alignment: center; }
                                        Text { width: 120px; text: "Ambalaj";    font-size: 13px; font-weight: 600; color: #475569; vertical-alignment: center; }
                                        Text { width: 180px; text: "Standard";   font-size: 13px; font-weight: 600; color: #475569; vertical-alignment: center; }
                                        Text { width: 100px; text: "Pret (RON)"; font-size: 13px; font-weight: 600; color: #475569; vertical-alignment: center; }
                                        Rectangle { horizontal-stretch: 1; }
                                    }
                                }

                                // Variation rows
                                for item[i] in variation-list: Rectangle {
                                    property <string> e-dims: item.dims;
                                    property <string> e-pack: item.pack;
                                    property <string> e-std: item.std;
                                    property <string> e-price: item.price;

                                    height: 48px;
                                    background: Math.mod(i, 2) == 0 ? #ffffff : #f1f5f9;
                                    border-color: #e2e8f0;
                                    border-width: 1px;

                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 8px;
                                        alignment: start;

                                        Rectangle {
                                            width: 140px; height: 32px;
                                            background: #ffffff;
                                            border-color: #cbd5e1;
                                            border-width: 1px;
                                            border-radius: 4px;
                                            TextInput {
                                                x: 6px; y: (parent.height - self.height) / 2;
                                                width: parent.width - 12px;
                                                vertical-alignment: center;
                                                font-size: 13px;
                                                color: #1e293b;
                                                text <=> e-dims;
                                                edited => {
                                                    root.variation-field-changed(i, e-dims, e-pack, e-std, e-price);
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: 120px; height: 32px;
                                            background: #ffffff;
                                            border-color: #cbd5e1;
                                            border-width: 1px;
                                            border-radius: 4px;
                                            TextInput {
                                                x: 6px; y: (parent.height - self.height) / 2;
                                                width: parent.width - 12px;
                                                vertical-alignment: center;
                                                font-size: 13px;
                                                color: #1e293b;
                                                text <=> e-pack;
                                                edited => {
                                                    root.variation-field-changed(i, e-dims, e-pack, e-std, e-price);
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: 180px; height: 32px;
                                            background: #ffffff;
                                            border-color: #cbd5e1;
                                            border-width: 1px;
                                            border-radius: 4px;
                                            TextInput {
                                                x: 6px; y: (parent.height - self.height) / 2;
                                                width: parent.width - 12px;
                                                vertical-alignment: center;
                                                font-size: 13px;
                                                color: #1e293b;
                                                text <=> e-std;
                                                edited => {
                                                    root.variation-field-changed(i, e-dims, e-pack, e-std, e-price);
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: 100px; height: 32px;
                                            background: #ffffff;
                                            border-color: #cbd5e1;
                                            border-width: 1px;
                                            border-radius: 4px;
                                            TextInput {
                                                x: 6px; y: (parent.height - self.height) / 2;
                                                width: parent.width - 12px;
                                                vertical-alignment: center;
                                                font-size: 13px;
                                                color: #1e293b;
                                                input-type: decimal;
                                                text <=> e-price;
                                                edited => {
                                                    root.variation-field-changed(i, e-dims, e-pack, e-std, e-price);
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            horizontal-stretch: 1;
                                            CustomButton {
                                                text: "Sterge";
                                                button-type: ButtonType.Danger;
                                                width: 80px;
                                                height: 30px;
                                                clicked => { root.remove-variation-row(i); }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
